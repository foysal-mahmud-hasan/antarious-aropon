# ---------------------------------------------------------------------------
# Aropon environment. Copy to `.env` and fill in. NEVER commit real secrets.
# Client vars MUST be prefixed EXPO_PUBLIC_ (bundled into the app — no secrets).
# Server vars are read by services/api only.
# ---------------------------------------------------------------------------

# --- Client (apps/mobile) ---
EXPO_PUBLIC_API_URL=http://localhost:8787
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_POWERSYNC_URL=https://YOUR-INSTANCE.powersync.journeyapps.com
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_SENTRY_DSN=

# --- Server (services/api) ---
NODE_ENV=development
PORT=8787
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aropon
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
POWERSYNC_URL=
ANTHROPIC_API_KEY=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
SENTRY_DSN=
RESEND_API_KEY=
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
