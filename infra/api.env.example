# Copy to /opt/aropon/api.env on the droplet (chmod 600). Read by the systemd service.

NODE_ENV=development
# ^ TEST BUILD: development enables dev OTP (code shown in-app) so testers log in without SMS.
#   Switch to production once Supabase Auth + SMS are wired.

PORT=8787
DATABASE_URL=postgres://aropon:CHANGE_THIS_PASSWORD@127.0.0.1:5432/aropon
AUTH_JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
SEED_DEMO=true
