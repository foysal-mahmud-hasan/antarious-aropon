{
  "name": "@aropon/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/server.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\" && cp -rf ../../packages/db/migrations dist/migrations",
    "start": "node dist/server.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(eslint configured at M0 CI step)\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@aropon/config": "workspace:*",
    "@aropon/core": "workspace:*",
    "@aropon/db": "workspace:*",
    "@aropon/validators": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@hono/trpc-server": "^0.3.4",
    "@trpc/server": "^11.0.0-rc.660",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.13",
    "jose": "^5.9.6",
    "postgres": "^3.4.5",
    "superjson": "^2.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
