{
  "name": "aropon",
  "version": "0.0.0",
  "private": true,
  "description": "Aropon — mobile-first SaaS business companion for Bangladeshi MSMEs (one app, tiered).",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
