    "test": "turbo run test",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "puppeteer-core": "23",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
